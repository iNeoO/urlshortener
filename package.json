{
  "name": "urlshortener",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "backend:dev": "dotenv -e .env -- pnpm --filter @urlshortener/backend backend:dev",
    "redirector:dev": "dotenv -e .env -- pnpm --filter @urlshortener/redirector dev",
    "backend:build": "dotenv -e .env -- pnpm --filter @urlshortener/backend build",
    "redirector:build": "dotenv -e .env -- pnpm --filter @urlshortener/redirector build",
    "infra:dev": "dotenv -e .env -- pnpm --filter @urlshortener/infra dev",
    "infra:build": "pnpm --filter @urlshortener/infra build",
    "common:dev": "pnpm --filter @urlshortener/common dev",
    "services:dev": "dotenv -e .env -- pnpm --filter @urlshortener/services dev:services",
    "services:build": "dotenv -e .env -- pnpm --filter @urlshortener/services build",
    "common:build": "pnpm --filter @urlshortener/common build",
    "frontend:dev": "dotenv -e .env -- pnpm --filter @urlshortener/frontend dev",
    "frontend:build": "dotenv -e .env -- pnpm --filter @urlshortener/frontend build",
    "db:build": "dotenv -e .env -- pnpm --filter @urlshortener/db build",
    "db:generate": "dotenv -e .env -- pnpm --filter @urlshortener/db generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @urlshortener/db migrate",
    "db:deploy": "dotenv -e .env -- pnpm --filter @urlshortener/db deploy",
    "db:reset": "dotenv -e .env -- pnpm --filter @urlshortener/db reset",
    "backend:start": "dotenv -e .env -- pnpm --filter @urlshortener/backend backend:start",
    "redirector:start": "dotenv -e .env -- pnpm --filter @urlshortener/redirector start",
    "worker:mail:dev": "dotenv -e .env -- pnpm --filter @urlshortener/notification-email-worker dev",
    "worker:mail:build": "dotenv -e .env -- pnpm --filter @urlshortener/notification-email-worker build",
    "worker:mail:start": "dotenv -e .env -- pnpm --filter @urlshortener/notification-email-worker start",
    "worker:stats-aggregate:dev": "dotenv -e .env -- pnpm --filter @urlshortener/stats-aggregate-worker dev",
    "worker:stats-aggregate:build": "dotenv -e .env -- pnpm --filter @urlshortener/stats-aggregate-worker build",
    "worker:stats-aggregate:start": "dotenv -e .env -- pnpm --filter @urlshortener/stats-aggregate-worker start",
    "cron:stats-aggregate:dev": "dotenv -e .env -- pnpm --filter @urlshortener/stats-aggregate-cron dev",
    "cron:stats-aggregate:build": "dotenv -e .env -- pnpm --filter @urlshortener/stats-aggregate-cron build",
    "cron:stats-aggregate:start": "dotenv -e .env -- pnpm --filter @urlshortener/stats-aggregate-cron start",
    "worker:stats-events:dev": "dotenv -e .env -- pnpm --filter @urlshortener/stats-events-worker dev",
    "worker:stats-events:build": "dotenv -e .env -- pnpm --filter @urlshortener/stats-events-worker build",
    "worker:stats-events:start": "dotenv -e .env -- pnpm --filter @urlshortener/stats-events-worker start",
    "frontend:start": "dotenv -e .env -- pnpm --filter @urlshortener/frontend preview",
    "dev:libs:build": "pnpm run common:build && pnpm run infra:build && pnpm run services:build",
    "dev:runtime": "concurrently -k \"pnpm run backend:dev\" \"pnpm run redirector:dev\" \"pnpm run frontend:dev\" \"pnpm run worker:mail:dev\" \"pnpm run worker:stats-aggregate:dev\" \"pnpm run worker:stats-events:dev\" \"pnpm run cron:stats-aggregate:dev\" \"dotenv -e .env -- pnpm --filter @urlshortener/stats-events-worker dev:build\"",
    "dev": "pnpm run dev:libs:build && pnpm run dev:runtime",
    "build": "pnpm run common:build && pnpm run infra:build && pnpm run services:build && pnpm run backend:build && pnpm run redirector:build && pnpm run frontend:build",
    "start": "concurrently -k \"pnpm run backend:start\" \"pnpm run redirector:start\" \"pnpm run worker:mail:start\" \"pnpm run worker:stats-aggregate:start\" \"pnpm run worker:stats-events:start\" \"pnpm run cron:stats-aggregate:start\" \"pnpm run frontend:start\"",
    "script:create-calls": "pnpm --filter @urlshortener/scripts create-calls",
    "script:create-random-stats": "dotenv -e .env -- pnpm --filter @urlshortener/scripts create-random-stats",
    "lint": "pnpm -r run lint"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv-cli": "^11.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
