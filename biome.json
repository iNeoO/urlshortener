{
	"$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"./apps/backend/src/**/*",
			"./apps/frontend/src/**/*",
			"./apps/redirector/src/**/*",
			"./apps/frontend/vite.config.ts",
			"!apps/frontend/src/*.gen.ts",
			"./db/src/**/*",
			"./scripts/src/**/*",
			"./packages/common/src/**/*",
			"./packages/infra/src/**/*",
			"./packages/services/src/**/*",
			"./workers/*/src/**/*"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
