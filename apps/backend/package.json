{
  "name": "@urlshortener/backend",
  "type": "module",
  "scripts": {
    "dev:backend": "tsx watch src/index.ts",
    "dev:workers": "tsx watch src/workers/index.ts",
    "test": "vitest",
    "build": "tsc",
    "start:backend": "node dist/index.js",
    "start:workers": "node dist/workers/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/standard-validator": "^0.2.2",
    "@prisma/adapter-pg": "^7.3.0",
    "@scalar/hono-api-reference": "^0.9.34",
    "@urlshortener/db": "workspace:*",
    "hono": "^4.11.5",
    "hono-openapi": "^1.1.2",
    "hono-pino": "^0.10.3",
    "ioredis": "^5.9.2",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "vitest": "^4.0.18",
    "zod": "^4.3.5"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./schema": {
      "import": {
        "types": "./dist/schemas/exports.d.ts",
        "default": "./dist/schemas/exports.js"
      }
    },
    "./hc": {
      "import": {
        "types": "./dist/libs/hc.d.ts",
        "default": "./dist/libs/hc.js"
      }
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/node": "^20.11.17",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
