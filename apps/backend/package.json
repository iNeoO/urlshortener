{
  "name": "@urlshortener/backend",
  "type": "module",
  "scripts": {
    "backend:dev": "tsx watch --clear-screen=false src/index.ts",
    "test": "vitest",
    "lint": "biome check",
    "build": "rm -rf dist && tsc",
    "backend:start": "node dist/index.js"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@hono/prometheus": "catalog:",
    "@hono/standard-validator": "catalog:",
    "@scalar/hono-api-reference": "catalog:",
    "@urlshortener/common": "workspace:*",
    "@urlshortener/db": "workspace:*",
    "@urlshortener/infra": "workspace:*",
    "@urlshortener/services": "workspace:*",
    "hono": "catalog:",
    "hono-openapi": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:",
    "@urlshortener/notification-email-worker": "workspace:*"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./schema": {
      "import": {
        "types": "./dist/schemas/exports.d.ts",
        "default": "./dist/schemas/exports.js"
      }
    },
    "./hc": {
      "import": {
        "types": "./dist/libs/hc.d.ts",
        "default": "./dist/libs/hc.js"
      }
    }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
